```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.env
.ENV
.env.*
.ENV.*

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak

# Compiled files
*.exe
*.dll
*.so
*.dylib
*.class
*.o
*.obj
*.out

# Archives
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z

# Cache directories
.cache/
.mypy_cache/
.pytest_cache/
.gradle/
target/
```